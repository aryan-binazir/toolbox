{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Scheduler",
  "version": "0.1.0",
  "identifier": "dev.ai-scheduler.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Scheduler",
        "width": 1280,
        "height": 860,
        "minWidth": 960,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self' 'unsafe-inline'; frame-ancestors 'none'; base-uri 'none'; form-action 'self'",
      "freezePrototype": true,
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "Permissions-Policy": "camera=(), microphone=(), geolocation=()"
      }
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
